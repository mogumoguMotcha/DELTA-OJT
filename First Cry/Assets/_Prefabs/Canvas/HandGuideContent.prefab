  m_text: 'First Image: "Your hand is hovering over the ''Continue'' button to proceed
    with the next step in the simulation."


    Second Image: "A blue ray from the
    hand highlights the ''Continue'' button, indicating an active selection ready
    to be triggered."


    Third Image: "A user is holding a clipboard, with hand
    tracking enabling a realistic interaction with virtual objects."


    Fourth
    Image: "Both hands are tracking a point system interaction, showing how hand
    gestures can be used to manipulate elements in the environment."'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
